# --- OpenAI runtime defaults ---
PARSER_MAX_ATTEMPTS=5
AWARE_PARSER_KB_FILE=knowledge/parser_buildspec_kb.md
AWARE_EXECUTOR_KB_FILE=knowledge/executor_rca_kb.md
EXECUTOR_MAX_AGENTS=5
AWARE_ENABLE_REASONING=true
AWARE_ENABLE_MEMORY=true

# --- OpenAI provider ---
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini

# --- UI defaults ---
UI_HOST=127.0.0.1
UI_PORT=8787
UI_DEFAULT_SOURCE_PATH=
